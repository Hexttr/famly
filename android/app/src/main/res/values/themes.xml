<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Famly" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/famly_primary</item>
        <item name="android:navigationBarColor">#1B4332</item>
        <item name="android:windowBackground">@color/famly_background</item>
    </style>

    <style name="Theme.Famly.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/logo_inset</item>
        <item name="postSplashScreenTheme">@style/Theme.Famly</item>
    </style>
</resources>
